# --- 本地数据（运行时生成，不入库）---
localdata_staging/

# 采集产物：骨架 JSON 与 sidecar（保留 *_annotation.json 与 pose 配对）
localdata/json/*
!localdata/json/.gitkeep
localdata/json/annotations/*
!localdata/json/annotations/.gitkeep
localdata/json/archive/*
!localdata/json/archive/.gitkeep

# 配套视频（体积大）
localdata/video/*
!localdata/video/.gitkeep

# 人工复核 event_review（与 pose tier 解耦，运行时生成）
localdata/review/*
!localdata/review/.gitkeep

# 上传临时目录（含 tmp_*、回放临时）
localdata/upload/*
!localdata/upload/.gitkeep
localdata/upload/playback_temp/*
!localdata/upload/playback_temp/.gitkeep

# ONNX 权重（OpenMMLab 下载，体积大）
localdata/models/onnx/detection/*
!localdata/models/onnx/detection/.gitkeep
localdata/models/onnx/pose/*
!localdata/models/onnx/pose/.gitkeep
# 旧版扁平目录（若仍保留本地权重）
localdata/models/rtmpose_onnx/

# 旧版/杂项会话数据
localdata/sessions/

# CLI 默认输出目录
output/

# --- 媒体与压缩包 ---
*.mp4
*.avi
*.mov
*.mkv
*.webm
*.m4v
*.zip
*.tar
*.tar.gz
*.7z

# --- IDE / 系统 ---
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db
desktop.ini

# --- 本机覆盖配置（可选，若后续增加 config.local.json）---
config.local.json
config.*.local.json

localdata/
*.svg
